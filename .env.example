# GoCanvas API authentication (choose one; listed in priority order).

# 1. OAuth 2.0 client credentials (preferred). The server fetches a short-lived
#    bearer token from /oauth/token and refreshes it automatically (and on 401).
GOCANVAS_CLIENT_ID=your_client_id
GOCANVAS_CLIENT_SECRET=your_client_secret
# GOCANVAS_OAUTH_SCOPE=api

# 2. Static bearer token.
# GOCANVAS_API_TOKEN=your_api_token_here

# 3. HTTP Basic auth.
# GOCANVAS_USERNAME=you@example.com
# GOCANVAS_PASSWORD=your_password

# Optional overrides.
# GOCANVAS_BASE_URL=https://api.gocanvas.com/api/v3
# GOCANVAS_PDF_DIR=./pdf_output
# GOCANVAS_TIMEOUT=30
